generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Admin {
  SDT_Admin  String    @id(map: "PK__Admin__574698DD3D443B4C") @db.VarChar(15)
  IDTaiKhoan Int?      @unique(map: "UQ__Admin__BC5F907D431E3E74")
  TaiKhoan   TaiKhoan? @relation(fields: [IDTaiKhoan], references: [IDTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_Admin_TaiKhoan")
}

model BaiViet {
  MaBaiViet Int       @id(map: "PK__BaiViet__AEDD564777C80470") @default(autoincrement())
  TieuDe    String    @db.NVarChar(255)
  NoiDung   String?   @db.NVarChar(Max)
  TacGia    String?   @db.NVarChar(255)
  LuotXem   Int?      @default(0, map: "DF__BaiViet__LuotXem__17F790F9")
  TrangThai String?   @default("N'Nháp'", map: "DF_BaiViet_TrangThai_Fixed") @db.NVarChar(50)
  NgayTao   DateTime? @default(now(), map: "DF__BaiViet__NgayTao__18EBB532") @db.DateTime
}

model Banner {
  MaBanner  Int       @id(map: "PK__Banner__508B4A4905632A64") @default(autoincrement())
  TieuDe    String    @db.NVarChar(255)
  HinhAnh   String?   @db.NVarChar(500)
  LinkURL   String?   @db.NVarChar(500)
  ViTri     String?   @db.NVarChar(100)
  TrangThai String?   @default("N'Đang hiển thị'", map: "DF_Banner_TrangThai_Fixed") @db.NVarChar(50)
  ThuTu     Int?      @default(0, map: "DF__Banner__ThuTu__1AD3FDA4")
  NgayTao   DateTime? @default(now(), map: "DF__Banner__NgayTao__1BC821DD") @db.DateTime
}

model ChiNhanh {
  MaChiNhanh     Int                @id(map: "PK__ChiNhanh__4B5BA5BD30E1A939") @default(autoincrement())
  TenChiNhanh    String?            @db.NVarChar(255)
  SDT_CN         String?            @db.VarChar(15)
  DiaChiChiNhanh String?            @db.NVarChar(500)
  Vouchers       Voucher_ChiNhanh[]
}

model ChiTietDonHang {
  MaCTDonHang Int         @id(map: "PK__ChiTietD__B9F4AB6C480D02EC") @default(autoincrement())
  MaDonHang   Int?
  VoucherID   Int?
  SoLuongMua  Int?
  DonGia      Decimal?    @db.Decimal(18, 2)
  ThanhTien   Decimal?    @db.Decimal(18, 2)
  DonHang     DonHang?    @relation(fields: [MaDonHang], references: [MaDonHang], onDelete: NoAction, onUpdate: NoAction, map: "FK_CTDH_DonHang")
  Voucher     Voucher?    @relation(fields: [VoucherID], references: [VoucherID], onDelete: NoAction, onUpdate: NoAction, map: "FK_CTDH_Voucher")
  MaVouchers  MaVoucher[]
}

model ChiTietGioHang {
  MaCTGioHang  Int       @id(map: "PK__ChiTietG__CE44847308AEFBE5") @default(autoincrement())
  MaGioHang    Int?
  VoucherID    Int?
  SoLuong      Int?
  ThoiGianThem DateTime? @default(now(), map: "DF__ChiTietGi__ThoiG__1CBC4616") @db.DateTime
  GioHang      GioHang?  @relation(fields: [MaGioHang], references: [MaGioHang], onDelete: NoAction, onUpdate: NoAction, map: "FK_CTGH_GioHang")
  Voucher      Voucher?  @relation(fields: [VoucherID], references: [VoucherID], onDelete: NoAction, onUpdate: NoAction, map: "FK_CTGH_Voucher")
}

model DanhGia {
  MaDanhGia   Int       @id(map: "PK__DanhGia__AA9515BF43E7C9B1") @default(autoincrement())
  VoucherID   Int?
  IDTaiKhoan  Int?
  DiemDanhGia Int?
  NoiDung     String?   @db.NVarChar(Max)
  NgayDanhGia DateTime? @default(now(), map: "DF__DanhGia__NgayDan__1DB06A4F") @db.DateTime
  PhanHoiXuLy String?   @db.NVarChar(Max)
  TaiKhoan    TaiKhoan? @relation(fields: [IDTaiKhoan], references: [IDTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_DanhGia_TaiKhoan")
  Voucher     Voucher?  @relation(fields: [VoucherID], references: [VoucherID], onDelete: NoAction, onUpdate: NoAction, map: "FK_DanhGia_Voucher")
}

model DanhMuc {
  MaDanhMuc  Int       @id(map: "PK__DanhMuc__B37508870F5B1359") @default(autoincrement())
  TenDanhMuc String    @db.NVarChar(255)
  MoTa       String?
  Vouchers   Voucher[]
}

model DoiTac {
  MaDoiTac          Int              @id(map: "PK__DoiTac__5F76BF3405CA18D7") @default(autoincrement())
  TenDoanhNghiep    String?          @db.NVarChar(255)
  MaSoThue          String?          @db.VarChar(50)
  CaNhanDaiDien     String?          @db.NVarChar(255)
  LinhVucKinhDoanh  String?          @db.NVarChar(255)
  TrangThaiPheDuyet String?          @db.NVarChar(50)
  TrangThaiHoatDong String?          @db.NVarChar(50)
  NhanViens         NhanVienDoiTac[]
  Vouchers          Voucher[]
}

model DonHang {
  MaDonHang           Int              @id(map: "PK__DonHang__129584AD3F311FB9") @default(autoincrement())
  IDTaiKhoan          Int?
  ThoiGianThanhToan   DateTime?        @db.DateTime
  TongTien            Decimal?         @db.Decimal(18, 2)
  PhuongThucThanhToan String?          @db.NVarChar(100)
  TrangThaiDonHang    String?          @db.NVarChar(50)
  TrangThaiThanhToan  String?          @db.NVarChar(50)
  ChiTietDonHangs     ChiTietDonHang[]
  TaiKhoan            TaiKhoan?        @relation(fields: [IDTaiKhoan], references: [IDTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_DonHang_TaiKhoan")
}

model FAQ {
  MaFAQ      Int     @id(map: "PK__FAQ__3C0B8B9F0FD34C8D") @default(autoincrement())
  CauHoi     String  @db.NVarChar(500)
  TraLoi     String? @db.NVarChar(Max)
  DanhMucFAQ String? @db.NVarChar(100)
  ThuTu      Int?    @default(0, map: "DF__FAQ__ThuTu__1F98B2C1")
  TrangThai  String? @default("N'Hiển thị'", map: "DF_FAQ_TrangThai_Fixed") @db.NVarChar(50)
}

model GioHang {
  MaGioHang   Int              @id(map: "PK__GioHang__F5001DA33F0FF583") @default(autoincrement())
  IDTaiKhoan  Int?             @unique(map: "UQ__GioHang__BC5F907DA6E7ACDF")
  ThoiGianTao DateTime?        @default(now(), map: "DF__GioHang__ThoiGia__208CD6FA") @db.DateTime
  ChiTiet     ChiTietGioHang[]
  TaiKhoan    TaiKhoan?        @relation(fields: [IDTaiKhoan], references: [IDTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_GioHang_TaiKhoan")
}

model KhachHang {
  SDT_KH          String    @id(map: "PK__KhachHan__DE78DCDA20E481C1") @db.VarChar(15)
  IDTaiKhoan      Int?      @unique(map: "UQ__KhachHan__BC5F907DF23FEAF8")
  NgaySinh        DateTime? @db.Date
  GioiTinh        String?   @db.NVarChar(10)
  DiaChiKhachHang String?   @db.NVarChar(500)
  TaiKhoan        TaiKhoan? @relation(fields: [IDTaiKhoan], references: [IDTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_KhachHang_TaiKhoan")
}

model MaVoucher {
  SoMaVoucher      String          @id(map: "PK__MaVouche__9FAD330E2FB336BF") @db.VarChar(100)
  MaCTDonHang      Int?
  TrangThaiSuDung  String?         @db.NVarChar(50)
  ThoiDiemPhatHanh DateTime?       @db.DateTime
  ThoiDiemSuDung   DateTime?       @db.DateTime
  ChiTietDonHang   ChiTietDonHang? @relation(fields: [MaCTDonHang], references: [MaCTDonHang], onDelete: NoAction, onUpdate: NoAction, map: "FK_MaVoucher_CTDonHang")
}

model NhanVienDoiTac {
  IDNhanVien Int       @id(map: "PK__NhanVien__7AC2D9F7A65FFDB0") @default(autoincrement())
  IDTaiKhoan Int?
  MaDoiTac   Int?
  ChucVu     String?   @db.NVarChar(100)
  DoiTac     DoiTac?   @relation(fields: [MaDoiTac], references: [MaDoiTac], onDelete: NoAction, onUpdate: NoAction, map: "FK_NhanVien_DoiTac")
  TaiKhoan   TaiKhoan? @relation(fields: [IDTaiKhoan], references: [IDTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK_NhanVien_TaiKhoan")
}

model TaiKhoan {
  IDTaiKhoan        Int              @id(map: "PK__TaiKhoan__BC5F907CF86EA0F4") @default(autoincrement())
  TenDangNhap       String           @unique(map: "UQ__TaiKhoan__55F68FC0DA17A03B") @db.VarChar(100)
  MatKhau           String           @db.VarChar(255)
  Email             String           @unique(map: "UQ__TaiKhoan__A9D10534E9CA9800") @db.VarChar(255)
  HoTenNguoiDung    String?          @db.NVarChar(255)
  TrangThaiTaiKhoan String?          @db.NVarChar(50)
  Admin             Admin?
  DanhGias          DanhGia[]
  DonHangs          DonHang[]
  GioHang           GioHang?
  KhachHang         KhachHang?
  NhanVienDoiTacs   NhanVienDoiTac[]
  SystemLog         SystemLog[]
}

model Voucher {
  VoucherID        Int                @id(map: "PK__Voucher__3AEE79C14FFCBDD0") @default(autoincrement())
  MaDanhMuc        Int?
  MaDoiTac         Int?
  TenVoucher       String             @db.NVarChar(255)
  MoTaVoucher      String?            @db.NVarChar(Max)
  MoTaDieuKien     String?            @db.NVarChar(Max)
  GiaGoc           Decimal            @db.Decimal(18, 2)
  GiaBan           Decimal            @db.Decimal(18, 2)
  ThoiGianBatDau   DateTime           @db.DateTime
  ThoiGianKetThuc  DateTime           @db.DateTime
  SoLuongChoPhep   Int
  SoLuongDaBan     Int?               @default(0, map: "DF__Voucher__SoLuong__22751F6C")
  TrangThaiVoucher String?            @db.NVarChar(50)
  ChiTietDonHangs  ChiTietDonHang[]
  ChiTietGioHangs  ChiTietGioHang[]
  DanhGias         DanhGia[]
  DanhMuc          DanhMuc?           @relation(fields: [MaDanhMuc], references: [MaDanhMuc], onDelete: NoAction, onUpdate: NoAction, map: "FK_Voucher_DanhMuc")
  DoiTac           DoiTac?            @relation(fields: [MaDoiTac], references: [MaDoiTac], onDelete: NoAction, onUpdate: NoAction, map: "FK_Voucher_DoiTac")
  ChiNhanhs        Voucher_ChiNhanh[]
}

model Voucher_ChiNhanh {
  STT             Int       @id(map: "PK__Voucher___CA1EB69006726527") @default(autoincrement())
  VoucherID       Int?
  MaChiNhanh      Int?
  TrangThaiApDung String?   @db.NVarChar(50)
  ChiNhanh        ChiNhanh? @relation(fields: [MaChiNhanh], references: [MaChiNhanh], onDelete: NoAction, onUpdate: NoAction, map: "FK_VoucherChiNhanh_ChiNhanh")
  Voucher         Voucher?  @relation(fields: [VoucherID], references: [VoucherID], onDelete: NoAction, onUpdate: NoAction, map: "FK_VoucherChiNhanh_Voucher")
}

model SystemLog {
  MaLog      Int       @id(map: "PK__SystemLo__3B98D24A1CB1748F") @default(autoincrement())
  IDTaiKhoan Int?
  HanhDong   String    @db.NVarChar(255)
  DoiTuong   String?   @db.NVarChar(255)
  ChiTiet    String?   @db.NVarChar(Max)
  DiaChiIP   String?   @db.VarChar(50)
  TrangThai  String?   @db.NVarChar(50)
  ThoiGian   DateTime? @default(now(), map: "DF__SystemLog__ThoiG__2180FB33") @db.DateTime
  TaiKhoan   TaiKhoan? @relation(fields: [IDTaiKhoan], references: [IDTaiKhoan], onDelete: NoAction, onUpdate: NoAction, map: "FK__SystemLog__IDTai__0D44F85C")
}
